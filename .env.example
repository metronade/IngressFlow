# Postgres
POSTGRES_USER=ingressflow
POSTGRES_PASSWORD=ingressflow
POSTGRES_DB=ingressflow

# Composed from the values above — used by api/worker/beat
DATABASE_URL=postgresql+asyncpg://ingressflow:ingressflow@postgres:5432/ingressflow

# Redis (broker + result backend + pub/sub + rate counters)
REDIS_URL=redis://redis:6379/0

# Tier-2 scrape traffic only — Tier-1 API calls always go direct (see PLAN.md §4.8)
PROXY_GATEWAY_URL=http://proxy:8888

# Encrypts PlatformCredential.secret_blob at rest (PLAN.md §10). This is a dev
# example key — generate your own for any real deployment:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=-pDnsjk6W8Mue3fLTZS6A4FMz30fBnMCkDS1iNwcq74=

# Signs JWTs (auth) and password-reset/email-verification tokens. Dev example
# key — generate your own for any real deployment:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=2XyST4vNg1JnuxSC-rfpZw5umx2YaNZElctFqDGv5jU

# Stripe (PLAN.md §5 credit/subscription framework). Left blank in dev — the
# billing routes detect this and return 503 "not configured" rather than
# crashing; wire real test-mode keys in from the Stripe dashboard to exercise
# Checkout for real. STRIPE_WEBHOOK_SECRET comes from `stripe listen` or the
# dashboard's webhook endpoint config; STRIPE_PRICE_ID is the recurring
# "paid tier" Price to check out.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Whoever registers with this email becomes admin (is_superuser + role=ADMIN)
# on registration — the one-time bootstrap since there's no admin panel yet
# to promote the first admin (PLAN.md §9 Phase 5). Leave blank to disable.
ADMIN_BOOTSTRAP_EMAIL=

# Flower's own basic-auth gate (PLAN.md §9 Phase 5 — "Flower behind admin
# auth"). Format: user:pass. Leave blank only for local dev.
FLOWER_BASIC_AUTH=admin:changeme

# Where the BROWSER (not this container) reaches the API/WebSocket — baked
# into the frontend at build time, so `docker compose build web` must be
# re-run after changing either of these. Pick the case that matches how
# you're actually reaching this deployment:
#   - pure local dev, browsing from the same machine as Docker: leave both
#     commented out (defaults to http(s)://localhost:8000 / ws(s)://…).
#   - a VM/server reached at an IP or domain, ports published directly
#     (no reverse proxy yet): set both to that host, e.g.
#       NEXT_PUBLIC_API_BASE=http://203.0.113.10:8000
#       NEXT_PUBLIC_WS_BASE=ws://203.0.113.10:8000
#   - Nginx Proxy Manager fronting everything on one domain (the intended
#     prod setup, docs/npm-proxy-hosts.md): set both to "" (empty) — the
#     frontend then calls same-origin, which NPM routes correctly.
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_WS_BASE=ws://localhost:8000
