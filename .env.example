# Postgres
POSTGRES_USER=ingressflow
POSTGRES_PASSWORD=ingressflow
POSTGRES_DB=ingressflow

# Composed from the values above — used by api/worker/beat
DATABASE_URL=postgresql+asyncpg://ingressflow:ingressflow@postgres:5432/ingressflow

# Redis (broker + result backend + pub/sub + rate counters)
REDIS_URL=redis://redis:6379/0

# Tier-2 scrape traffic only — Tier-1 API calls always go direct (see PLAN.md §4.8)
PROXY_GATEWAY_URL=http://proxy:8888

# Encrypts PlatformCredential.secret_blob at rest (PLAN.md §10). This is a dev
# example key — generate your own for any real deployment:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=-pDnsjk6W8Mue3fLTZS6A4FMz30fBnMCkDS1iNwcq74=
