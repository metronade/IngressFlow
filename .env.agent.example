# RZ's public agent WebSocket endpoint (PLAN.md §4.8a). Once NPM fronts the
# gateway's internal :8889 on the main domain: wss://<domain>/agent/connect
GATEWAY_URL=wss://your-domain.example.com/agent/connect

# Generated once when this node is added in /admin/proxy-nodes — shown only
# at that moment, paste it here exactly.
AGENT_TOKEN=
